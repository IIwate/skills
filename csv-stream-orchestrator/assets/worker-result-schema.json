{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "exec_state",
    "min_verify_state",
    "artifact",
    "files_changed",
    "commands_run",
    "error_code",
    "error_summary",
    "notes"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "exec_state": { "type": "string", "enum": ["implemented", "blocked", "worker_failed"] },
    "min_verify_state": { "type": "string", "enum": ["unknown", "pass", "fail", "skip"] },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "deliverables"],
      "properties": {
        "summary": { "type": "string" },
        "deliverables": { "type": "array", "items": { "type": "string" } }
      }
    },
    "files_changed": { "type": "array", "items": { "type": "string" } },
    "commands_run": { "type": "array", "items": { "type": "string" } },
    "error_code": { "type": "string", "pattern": "^(|WORKER_[A-Z0-9_]+)$" },
    "error_summary": { "type": "string" },
    "notes": { "type": "string" }
  }
}
